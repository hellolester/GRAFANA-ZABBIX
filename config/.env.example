###############################################################################
# open-monitoring-stack-grafana-zabbix
# Environment configuration template
#
# Copy this file to config/.env and fill in real values, OR let install.sh
# generate config/.env interactively / non-interactively on first run.
#
# NEVER commit config/.env to version control. It is already listed in
# .gitignore. This file (.env.example) must never contain real secrets.
###############################################################################

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
MONITORING_HOSTNAME=monitoring.example.local
SYSTEM_TIMEZONE=Asia/Kuala_Lumpur

# ---------------------------------------------------------------------------
# MariaDB / Database
# ---------------------------------------------------------------------------
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
DB_NAME=zabbix
DB_USER=zabbix
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_HOST=localhost
DB_PORT=3306

# ---------------------------------------------------------------------------
# Zabbix
# ---------------------------------------------------------------------------
ZABBIX_VERSION=7.0
ZABBIX_ADMIN_USER=Admin
ZABBIX_ADMIN_PASSWORD=CHANGE_ME_ZABBIX_ADMIN_PASSWORD
ZABBIX_SERVER_PORT=10051
ZABBIX_AGENT_PORT=10050

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GRAFANA_VERSION=11.3.0
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD
GRAFANA_ZABBIX_PLUGIN=alexanderzobnin-zabbix-app

# ---------------------------------------------------------------------------
# Nginx / Web
# ---------------------------------------------------------------------------
WEB_LISTEN_PORT=80
ZABBIX_URL_PATH=/zabbix

# ---------------------------------------------------------------------------
# SNMP defaults (used only as suggested defaults in templates/docs)
# ---------------------------------------------------------------------------
SNMP_DEFAULT_VERSION=2c
SNMP_DEFAULT_COMMUNITY=public_ro_CHANGE_ME
SNMP_V3_DEFAULT_SECURITY_LEVEL=authPriv

# ---------------------------------------------------------------------------
# Notifications (optional - leave blank to skip configuration)
# ---------------------------------------------------------------------------
NOTIFY_EMAIL_SMTP_HOST=
NOTIFY_EMAIL_SMTP_PORT=587
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_USER=
NOTIFY_EMAIL_PASSWORD=

NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=

NOTIFY_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Firewall
# ---------------------------------------------------------------------------
ENABLE_FIREWALL=true
FIREWALL_ALLOW_SSH_PORT=22
